# =============================================================================
# Priya's Reinigungsservice — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Project URL: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Publishable / anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Project ref (the subdomain part, used by `supabase` CLI)
NEXT_PUBLIC_SUPABASE_PROJECT_ID=

# Service role key — SERVER-ONLY. Used by background jobs / edge functions.
# Never import this from a client component. Never commit it.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---------------------------------------------------------------------
# Public app URL, used for OAuth redirects and email links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Default locale (de | en)
NEXT_PUBLIC_DEFAULT_LOCALE=de
# UUID of the org self-serve signups join. Defaults to the seeded Priya org.
NEXT_PUBLIC_DEFAULT_ORG_ID=00000000-0000-0000-0000-0000000000aa

# --- Integrations (stubbed in v1; leave empty until wired up) ---------------
# Lexware
LEXWARE_API_BASE_URL=
LEXWARE_API_TOKEN=
# WhatsApp via Twilio (or your provider of choice)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Email (transactional). Resend recommended; swap for your provider.
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@example.com

# --- Feature flags -----------------------------------------------------------
NEXT_PUBLIC_FEATURE_LEXWARE_SYNC=false
NEXT_PUBLIC_FEATURE_WHATSAPP_NOTIFICATIONS=false
NEXT_PUBLIC_FEATURE_REALTIME_CHAT=true
