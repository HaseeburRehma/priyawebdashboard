# Use the npm v6-style resolution: allow installs to proceed even when
# transitive peer-dependency ranges conflict. Modern packages (Stagehand
# pinning zod to a tiny window, react-hook-form requiring a newer one,
# etc.) routinely disagree, but in practice they work fine together.
#
# Removing this file will surface the warnings again — keep it unless you
# need the strict resolution that npm@7+ enabled by default.
legacy-peer-deps=true
